                    }
                },
                "addresses": {
                    "@id": "https://314pool.com/cips/governance-feedback#addresses",
                    "@container": "@set",
                    "@context": {
                        "uri":         "https://cips.cardano.org/cip/CIP-0100#reference-uri",
