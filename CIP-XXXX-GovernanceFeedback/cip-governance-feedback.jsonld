                        "hash":     "https://314pool.com/cips/governance-feedback#subject-hash",
                        "actionId": "https://314pool.com/cips/governance-feedback#subject-actionId",
                        "label":    "https://cips.cardano.org/cip/CIP-0100#reference-label"
                    }
                },

                "content":            "https://314pool.com/cips/governance-feedback#content",
                "proposedActionType": "https://314pool.com/cips/governance-feedback#proposedActionType",
                "revision":           "https://314pool.com/cips/governance-feedback#revision",
                "status":             "https://314pool.com/cips/governance-feedback#status",
                "submittedAs":        "https://314pool.com/cips/governance-feedback#submittedAs",

                "feedbackType":  "https://314pool.com/cips/governance-feedback#feedbackType",
                "inReplyTo": {
                    "@id": "https://314pool.com/cips/governance-feedback#inReplyTo",
                    "@container": "@set"
                },
                "conditions": {
                    "@id": "https://314pool.com/cips/governance-feedback#conditions",
                    "@container": "@set",
                    "@context": {
                        "description":  "https://314pool.com/cips/governance-feedback#condition-description",
                        "criticality":  "https://314pool.com/cips/governance-feedback#condition-criticality",
                        "addressedBy":  "https://314pool.com/cips/governance-feedback#condition-addressedBy"
                    }
                },
                "votingIntent": {
                    "@id": "https://314pool.com/cips/governance-feedback#votingIntent",
                    "@context": {
                        "role":       "https://314pool.com/cips/governance-feedback#votingIntent-role",
                        "identifier": "https://314pool.com/cips/governance-feedback#votingIntent-identifier",
                        "stance":     "https://314pool.com/cips/governance-feedback#votingIntent-stance"
                    }
                },

                "addendumType": "https://314pool.com/cips/governance-feedback#addendumType",
