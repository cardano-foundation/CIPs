          "@id": "CIP100:externalUpdates",
          "@context": {
            "title": "CIP100:update-title",
            "uri": "CIP100:update-uri"
          }
        },
        "onChain": {
          "@id": "CIP169:onChain",
          "@context": {
            "@vocab": "https://github.com/cardano-foundation/CIPs/blob/master/CIP-0116/README.md#",
