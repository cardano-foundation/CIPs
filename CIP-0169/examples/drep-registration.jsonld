                        "data_hash": "CIP116:data_hash"
                      }
                    },
                    "script_hash": "CIP116:script_hash"
                  }
                }
              }
            },
            "key": {
              "@id": "CIP116:voter",
              "@context": {
                "tag": "CIP116:tag",
