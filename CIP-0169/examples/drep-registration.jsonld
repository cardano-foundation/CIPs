              }
            },
            "committee_cold_credential": {
              "@id": "CIP116:committee_cold_credential",
              "@context": {
                "tag": "CIP116:tag",
                "value": "CIP116:credential_value"
              }
            },
            "gov_action": {
              "@id": "CIP116:gov_action",
              "@context": {
                "tag": "CIP116:tag",
                "gov_action_id": {
                  "@id": "CIP116:gov_action_id",
                  "@context": {
                    "transaction_id": "CIP116:transaction_id",
