  "body": {
    "title": "CIP-0169 Example: Treasury Withdrawal (Preview)",
    "abstract": "Withdraw 100,000 test ada on Preview to demonstrate CIP-0169 on-chain binding of a treasury withdrawal.",
    "motivation": "Live examples let tools test CIP-0169 verification against real chain data.",
    "rationale": "The rewards destination below is bound into the signed body, demonstrating protection against metadata replay.",
    "references": [
      {
        "@type": "Other",
        "label": "Project milestone report",
        "uri": "https://example.com/milestones.pdf"
      }
    ],
