  "hashAlgorithm": "blake2b-256",
  "body": {
    "title": "CIP-0169 Example: Parameter Change (Preview)",
    "abstract": "Update maxBlockBodySize parameter from 90112 to 98304 bytes on the Preview testnet.",
    "motivation": "Demonstrates CIP-0169 binding of a protocol parameter update, including the previous governance action id.",
    "rationale": "The bound protocol_param_update and gov_action_id make replay against a different parameter change machine-detectable.",
    "onChain": {
      "deposit": "1000000000",
      "reward_account": "stake_test1uz6ljatyc7w52z44hskd5pu5cvw7qemwz6re3ux4pmdqumcn2qyrx",
      "gov_action": {
        "tag": "parameter_change_action",
        "protocol_param_update": {
          "max_block_body_size": 98304
        },
        "gov_action_id": {
          "transaction_id": "2a2dc37b22939d3ae7395c8a409d4d0625201c88926d641d6f4441c3287e39ba",
          "gov_action_index": "0"
        },
        "policy_hash": "fa24fb305126805cf2164c161d852a0e7330cf988f1fe558cf7d4a64"
      }
    }
  },
