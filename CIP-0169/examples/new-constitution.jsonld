  "hashAlgorithm": "blake2b-256",
  "body": {
    "title": "Adopt the Cardano Constitution v1",
    "abstract": "Enact the ratified Constitution document and its guardrails script.",
    "motivation": "The interim constitution should be replaced by the community-ratified version.",
    "rationale": "The Constitution.anchor below is RETAINED: it points to a separate artifact (the constitution document), which is itself part of the on-chain effect being voted on.",
    "onChain": {
      "deposit": "100000000000",
      "reward_account": "stake1uxsm9s75uhm20wxf6rsl9ga5chtw079fkrqa9cl55kmv0kqfk32j7",
